{
  "name": "shouryaps.com",
  "description": "Personal home page build using Gatsby and Stackrole's Foundation Starter",
  "version": "1.0.0",
  "author": "Shourya Pratap Singh <shourya4@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/shouryaps/shouryaps.com.git"
  },
  "bugs": {
    "url": "https://github.com/shouryaps/shouryaps.com/issues"
  },
  "scripts": {
    "build": "GATSBY_EXPERIMENTAL_PAGE_BUILD_ON_DATA_CHANGES=true gatsby build --log-pages",
    "develop": "gatsby develop",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "echo \"Write tests! -> https://gatsby.dev/unit-testing\" && exit 1"
  },
  "dependencies": {
    "framer-motion": "^2.6.5",
    "gatsby": "^2.21.33",
    "gatsby-background-image": "^1.1.1",
    "gatsby-image": "^2.4.3",
    "gatsby-plugin-advanced-sitemap": "^1.5.4",
    "gatsby-plugin-google-analytics": "^2.3.2",
    "gatsby-plugin-manifest": "^2.4.3",
    "gatsby-plugin-offline": "^3.2.2",
    "gatsby-plugin-react-helmet": "^3.3.1",
    "gatsby-plugin-sass": "^2.3.1",
    "gatsby-plugin-sharp": "^2.6.3",
    "gatsby-remark-images": "^3.3.3",
    "gatsby-remark-prismjs": "^3.5.1",
    "gatsby-remark-reading-time": "^1.1.0",
    "gatsby-remark-responsive-iframe": "^2.4.2",
    "gatsby-source-filesystem": "^2.3.3",
    "gatsby-transformer-remark": "^2.8.8",
    "gatsby-transformer-sharp": "^2.5.2",
    "node-sass": "^4.14.1",
    "prismjs": "^1.20.0",
    "react": "^16.12.0",
    "react-dom": "^16.12.0",
    "react-helmet": "^6.0.0",
    "react-icons": "^3.10.0"
  },
  "devDependencies": {
    "acorn": "^6.4.1",
    "prettier": "2.0.5",
    "react-refresh": "^0.8.2",
    "redux": "^3.0.0",
    "typescript": "^3.9.2"
  }
}
